# Public site URL (no trailing slash). Used to build auth callbacks + Stripe
# success/cancel URLs. In production set this to the canonical origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Project settings → API. The anon (publishable) key is safe in the browser; the
# service role key MUST stay server-side (it bypasses RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ------------------------------------------------------------------
# Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Created when you wire up the /api/stripe/webhook endpoint (see README).
STRIPE_WEBHOOK_SECRET=
# Price ID for the one-time EZStemz license purchase (Products → your product
# → pricing). This is the LIVE EZStemz price — do not remove it. The
# /api/checkout route reads this directly, so EZStemz purchases keep working.
EZSTEMZ_STRIPE_PRICE_ID=

# Price ID for KitForge — leave blank until the KitForge Stripe product exists.
# While empty, KitForge shows "Coming Soon" and its purchase button is disabled
# (see src/lib/products.ts → PRODUCTS.kitforge). Once you create the price in
# Stripe, paste the price_id here and flip `enabled: true` in products.ts.
KITFORGE_STRIPE_PRICE_ID=

# --- GitHub Releases (per product) -------------------------------------------
# Each product downloads its installers (DMG + Windows -Setup.exe) from its own
# GitHub repo. Set one owner/repo per product.
#
# EZStemz: EZSTEMZ_GITHUB_REPO takes precedence; if unset it falls back to the
# legacy GITHUB_REPO below (kept for backward-compat).
EZSTEMZ_GITHUB_REPO=orange-groove/ez-stemz
# EZSTEMZ_GITHUB_REPO=orange-groove/ez-stemz
# KitForge: leave blank until its release repo exists. While unset, the KitForge
# download page shows an empty "no builds published" state.
KITFORGE_GITHUB_REPO=
#
# Token used to read private release repos. A single shared GITHUB_TOKEN is used
# for every product by default; override per-product with EZSTEMZ_GITHUB_TOKEN /
# KITFORGE_GITHUB_TOKEN only if they live under different accounts. Fine-grained
# PAT with Contents: read on the repo(s) (or classic `repo` scope).
GITHUB_TOKEN=
# EZSTEMZ_GITHUB_TOKEN=
# KITFORGE_GITHUB_TOKEN=
